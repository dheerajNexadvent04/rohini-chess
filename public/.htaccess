RewriteEngine On
RewriteBase /

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.rohinichessacademy\.com$ [NC]
RewriteRule ^(.*)$ https://rohinichessacademy.com/$1 [L,R=301]

# SPA fallback — serve index.html for all non-file, non-directory requests
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
